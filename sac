#!/usr/bin/env bash
# SAC, SSH alias creator — appends a Host entry to ~/.ssh/config
set -uo pipefail

readonly SSH_DIR="$HOME/.ssh"
readonly SSH_CONFIG="$SSH_DIR/config"

usage() {
    cat <<'EOF'
Usage: sac <alias> [<user>@]<hostname> [-p <port>] [-X]

  <alias>      Short name to use for 'ssh <alias>'
  <hostname>   Hostname or IP to connect to, optionally prefixed with user@
  -p <port>    SSH port (default: 22)
  -X           Disable X11 forwarding (enabled by default; used for
               clipboard-over-ssh in tools like vim)
  -h           Show this help

Examples:
  sac web1 deploy@203.0.113.10
  sac web2 root@10.0.0.5 -p 2222
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    usage
    exit 0
fi

if [ "$#" -lt 2 ]; then
    usage >&2
    exit 1
fi

short=$1
arg=$2
shift 2

port=""
forward_x11="yes"

while getopts ":p:Xh" opt; do
    case "$opt" in
        p) port=$OPTARG ;;
        X) forward_x11="" ;;
        h) usage; exit 0 ;;
        \?) echo "Unknown option: -$OPTARG" >&2; usage >&2; exit 1 ;;
        :) echo "Option -$OPTARG requires an argument" >&2; exit 1 ;;
    esac
done

if [ -z "$short" ] || [[ "$short" =~ [[:space:]] ]]; then
    echo "Invalid alias '$short'" >&2
    exit 1
fi

if [[ "$arg" == *"@"* ]]; then
    user="${arg%%@*}"
    host="${arg##*@}"
else
    user=""
    host="$arg"
fi

if [ -z "$host" ]; then
    echo "No hostname found" >&2
    exit 1
fi

if [ -n "$port" ] && ! [[ "$port" =~ ^[0-9]+$ && "$port" -ge 1 && "$port" -le 65535 ]]; then
    echo "Invalid port '$port'" >&2
    exit 1
fi

if [ ! -d "$SSH_DIR" ]; then
    mkdir -p "$SSH_DIR"
    chmod 700 "$SSH_DIR"
fi
if [ ! -f "$SSH_CONFIG" ]; then
    touch "$SSH_CONFIG"
    chmod 600 "$SSH_CONFIG"
fi

if grep -iFxq "Host $short" "$SSH_CONFIG"; then
    echo "Alias '$short' already exists in $SSH_CONFIG" >&2
    exit 1
fi

if grep -iFxq "  HostName $host" "$SSH_CONFIG"; then
    echo "HostName/IP '$host' already exists in $SSH_CONFIG" >&2
    exit 1
fi

{
    echo
    echo "Host $short"
    echo "  HostName $host"
    if [ -n "$user" ]; then
        echo "  User     $user"
    fi
    if [ -n "$port" ]; then
        echo "  Port     $port"
    fi
    if [ -n "$forward_x11" ]; then
        echo "  ForwardX11 yes"
        echo "  ForwardX11Trusted yes"
    fi
} >> "$SSH_CONFIG"

echo "Added alias '$short' for $host to $SSH_CONFIG"
if [ -n "$user" ]; then
    echo "  User: $user"
fi
if [ -n "$port" ]; then
    echo "  Port: $port"
fi
if [ -n "$forward_x11" ]; then
    echo "  X11 forwarding: enabled"
fi
